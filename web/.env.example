# SubmitSense API base URL. The NestJS backend runs on :3000 with a /api/v1
# prefix; the Next.js dev server runs on :3001 to avoid the port clash.
API_BASE_URL=http://localhost:3000/api/v1

# Dev auth stub. When "1", the app uses a canned session (see
# src/lib/session/dev-stub.ts) so the UI can be built and demoed before Cognito
# is wired. MUST be unset (or "0") in production so real Cognito tokens are used.
DEV_AUTH=0
