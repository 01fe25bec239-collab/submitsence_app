environment             = "dev"
vpc_cidr                = "10.20.0.0/16"
single_nat_gateway      = true
enable_dr               = false
force_destroy_buckets   = true
allow_insecure_http     = true
db_instance_class       = "db.t4g.micro"
db_allocated_storage    = 20
db_max_allocated_storage = 100
db_backup_retention_days = 7
api_capacity            = { initial = 1, min = 1, max = 3, pool_max = 5 }
frontend_capacity       = { initial = 1, min = 1, max = 3 }
worker_capacities = {
  ocr       = { initial = 0, min = 0, max = 1 }
  vendor    = { initial = 0, min = 0, max = 1 }
  package   = { initial = 0, min = 0, max = 1 }
  scheduled = { initial = 1, min = 1, max = 2 }
}
monthly_budget_usd      = 150

# Add these together after purchasing a domain and creating its Route53 zone.
root_domain    = ""
route53_zone_id = ""
