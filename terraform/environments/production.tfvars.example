environment              = "production"
vpc_cidr                 = "10.40.0.0/16"
single_nat_gateway       = false
enable_dr                = true
force_destroy_buckets    = false
allow_insecure_http      = false
db_instance_class        = "db.r7g.large"
db_allocated_storage     = 100
db_max_allocated_storage = 1000
db_backup_retention_days = 35
api_capacity             = { initial = 2, min = 2, max = 10, pool_max = 10 }
frontend_capacity        = { initial = 2, min = 2, max = 10 }
worker_capacities = {
  ocr       = { initial = 0, min = 0, max = 4 }
  vendor    = { initial = 0, min = 0, max = 4 }
  package   = { initial = 0, min = 0, max = 4 }
  scheduled = { initial = 1, min = 1, max = 4 }
}
monthly_budget_usd       = 2500

# Public launch intentionally remains blocked until these are set.
root_domain     = ""
route53_zone_id = ""
